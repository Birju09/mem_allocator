[settings]
os=Linux
arch=armv8
compiler=clang
compiler.version=18
compiler.libcxx=libstdc++11
compiler.cppstd=20
build_type=Release

[conf]
tools.cmake.cmaketoolchain:generator=Unix Makefiles
tools.build:sharedlinkflags=["-fuse-ld=lld-18"]
tools.build:exelinkflags=["-fuse-ld=lld-18"]

[buildenv]
CC=clang-18
CXX=clang++-18
AR=llvm-ar-18
LD=lld-18
